# bogie website — required environment variables (no real values here)

# --- Server-side secrets (contact form email via Gmail SMTP) ---
# Local dev: put real values in .dev.vars (wrangler dev) and/or .env (next dev).
# Production (Cloudflare Workers): set with `wrangler secret put CONTACT_EMAIL_USER`
# and `wrangler secret put CONTACT_EMAIL_APP_PASSWORD` — never commit them.
CONTACT_EMAIL_USER=your-gmail-address@gmail.com
CONTACT_EMAIL_APP_PASSWORD=your_gmail_app_password_here

# --- Public (exposed to the browser via NEXT_PUBLIC_ prefix — safe by design) ---
# Railway backend API base URL
NEXT_PUBLIC_API_URL=https://your-backend.example.com
# Ola Maps (Krutrim) client key — used for client-side autocomplete/tiles
NEXT_PUBLIC_OLA_MAPS_KEY=your_ola_maps_api_key_here
